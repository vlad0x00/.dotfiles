#!/bin/bash
set -euo pipefail

BACKUP_DIRS=("projects" "random" "archive")
COMPRESSION_LEVEL=19
DEPS=("pv" "zstd" "gpg" "numfmt")

TIMESTAMP=$(date +%F)
BACKUP_FILE="backup-$TIMESTAMP.tar.zst.gpg"

# ======= helpers ========

die()   { echo "Error: $*" >&2; exit 1; }
human() { numfmt --to=iec-i --suffix=B "$1"; }

confirm() {
    local reply
    read -erp "$1 (y/n): " reply
    [[ $reply == [yY] ]] || exit 1
}

gpg_pw() {  # gpg_pw <passphrase> <gpg args...>
    local pw=$1; shift
    gpg --batch --pinentry-mode loopback --passphrase-fd 3 "$@" 3<<<"$pw"
}

cleanup() {
    [[ -f $BACKUP_FILE.tmp ]] && {
        echo -e "\nAborted; removing partial archive." >&2
        rm -f "$BACKUP_FILE.tmp"
    }
    trap - EXIT
    exit 1
}
trap cleanup INT TERM EXIT

# ======= checks ========

for dir in "${BACKUP_DIRS[@]}"; do
    [[ -d $dir ]] || die "directory '$dir' does not exist."
done
for cmd in "${DEPS[@]}"; do
    command -v "$cmd" >/dev/null || die "'$cmd' is required but not installed."
done

TOTAL_SIZE=$(du -csb "${BACKUP_DIRS[@]}" | tail -1 | cut -f1)
NEEDED_SPACE=$(( TOTAL_SIZE + TOTAL_SIZE / 10 ))          # +10% buffer
AVAILABLE_SPACE=$(df -B1 --output=avail . | tail -1)

if (( AVAILABLE_SPACE < NEEDED_SPACE )); then
    echo "Warning: possibly insufficient disk space."
    echo "  Needed (~+10%): $(human "$NEEDED_SPACE")"
    echo "  Available:      $(human "$AVAILABLE_SPACE")"
    confirm "Continue anyway?"
fi

[[ -f $BACKUP_FILE ]] && confirm "File '$BACKUP_FILE' exists. Overwrite?"

read -erp "Enter encryption password: " PASSWORD; echo

# ======= backup ========

echo "Backing up: ${BACKUP_DIRS[*]}"
echo "Uncompressed size: $(human "$TOTAL_SIZE")"

if ! tar -cf - "${BACKUP_DIRS[@]}" \
        | pv -s "$TOTAL_SIZE" \
        | zstd "-$COMPRESSION_LEVEL" -T0 \
        | gpg_pw "$PASSWORD" -c -o "$BACKUP_FILE.tmp"; then
    die "backup creation failed."
fi

mv "$BACKUP_FILE.tmp" "$BACKUP_FILE"
COMPRESSED_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
echo "Backup complete: $BACKUP_FILE ($COMPRESSED_SIZE)"

# ======= verify ========

read -erp "Re-enter password to verify: " VERIFY_PASSWORD; echo

if gpg_pw "$VERIFY_PASSWORD" --decrypt --dry-run "$BACKUP_FILE" >/dev/null 2>&1; then
    echo "✅ Verified. Compression: $(human "$TOTAL_SIZE") → $COMPRESSED_SIZE"
else
    die "❌ password verification failed (mismatch or corrupt archive)."
fi

trap - EXIT INT TERM
echo "Restore with: gpg -d '$BACKUP_FILE' | zstd -d | tar -xf -"
